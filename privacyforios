<script>
  const titleMap = { ko:'개인정보처리방침', en:'Privacy Policy' };
  const effMap = { ko:'시행일: 2026년 6월 28일', en:'Effective: June 28, 2026' };
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const doc = tab.dataset.doc;
      document.querySelectorAll('.tab').forEach(item => {
        const on = item === tab;
        item.classList.toggle('on', on);
        item.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      document.querySelectorAll('.doc').forEach(item => item.classList.toggle('on', item.id === doc));
      document.documentElement.lang = doc;
      document.getElementById('title').textContent = titleMap[doc];
      document.getElementById('eff').textContent = effMap[doc];
    });
  });
</script>
